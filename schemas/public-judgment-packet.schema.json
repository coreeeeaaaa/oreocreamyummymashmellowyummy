{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/oreocreamyummy/public-judgment-packet.schema.json",
  "title": "Public Judgment Packet",
  "type": "object",
  "required": [
    "target",
    "scope",
    "not_scope",
    "purpose",
    "claims",
    "evidence",
    "srvl_results",
    "gate_results",
    "axis_reviews",
    "defect_register",
    "forbidden_promotion_clean",
    "forbidden_promotion_findings",
    "redaction_clean",
    "redaction_findings",
    "required_next_action",
    "final_verdict"
  ],
  "properties": {
    "target": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "not_scope": { "type": "array", "items": { "type": "string" } },
    "purpose": { "type": "string", "minLength": 1 },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "claim_text", "evidence_refs", "claimed_level"],
        "properties": {
          "claim_id": { "type": "string", "minLength": 1 },
          "claim_text": { "type": "string", "minLength": 1 },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "claimed_level": { "type": "string", "pattern": "^L([0-9]|1[0-6])$" }
        },
        "additionalProperties": false
      }
    },
    "srvl_results": {
      "type": "object",
      "required": ["highest_passed_level", "first_blocking_level", "blocking_reason"],
      "properties": {
        "highest_passed_level": { "type": "string", "pattern": "^L([0-9]|1[0-6])$" },
        "first_blocking_level": { "type": ["string", "null"], "pattern": "^L([0-9]|1[0-6])$" },
        "blocking_reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_id", "evidence_class", "summary"],
        "properties": {
          "evidence_id": { "type": "string" },
          "evidence_class": { "enum": ["A", "B", "C", "D", "E", "F"] },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "gate_results": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["gate_id", "verdict", "summary"],
        "properties": {
          "gate_id": {
            "type": "integer",
            "minimum": 0,
            "maximum": 11
          },
          "verdict": {
            "enum": ["PASS", "HOLD", "FAIL"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "axis_reviews": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["axis", "verdict", "summary"],
        "properties": {
          "axis": {
            "enum": ["theory", "design", "implementation", "environment", "operations"]
          },
          "verdict": {
            "enum": ["PASS", "HOLD", "FAIL", "NOT_APPLICABLE"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "defect_register": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["defect_id", "severity", "axis", "summary", "required_action"],
        "properties": {
          "defect_id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["P0", "P1", "P2", "P3", "P4"] },
          "axis": {
            "enum": [
              "theory",
              "design",
              "implementation",
              "environment",
              "operations",
              "cross_axis",
              "unclassified"
            ]
          },
          "summary": { "type": "string", "minLength": 1 },
          "required_action": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "forbidden_promotion_clean": { "type": "boolean" },
    "forbidden_promotion_findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "redaction_clean": { "type": "boolean" },
    "redaction_findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_next_action": { "type": "string" },
    "final_verdict": {
      "enum": [
        "PASS_SCOPED",
        "HOLD_EXACT_BLOCKER",
        "FAIL_CONTRADICTED",
        "REJECT_OVERCLAIM",
        "REDACTION_REQUIRED"
      ]
    }
  },
  "additionalProperties": false
}
